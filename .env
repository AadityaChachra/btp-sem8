# LLM model: provider/model-id (CrewAI/LiteLLM format)
# Default is Groq. Change to use another provider and set the matching API key below.
MODEL=ollama/llama3.2

# --- Pick one provider and set its key ---
# FREE: Groq, Google Gemini, Ollama (local). PAID: OpenAI, Anthropic.

# Groq (default) — FREE — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini — FREE tier — https://aistudio.google.com/apikey
# MODEL=gemini/gemini-2.0-flash
# GOOGLE_API_KEY=your_google_ai_key_here

# Ollama — FREE, local (no key) — https://ollama.ai then: ollama run llama3.2
# MODEL=ollama/llama3.2

# OpenAI — paid (free token program has limits) — https://platform.openai.com/api-keys
# MODEL=openai/gpt-4o
# OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic (Claude) — paid — https://console.anthropic.com/
# MODEL=anthropic/claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=your_anthropic_key_here
